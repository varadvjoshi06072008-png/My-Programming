#include <stdio.h>

int count(char And[]);

int main() {
    char And[20];

    fgets(And, 20, stdin);

    printf("%d\n", count(And));

    return 0;
}

int count(char And[]) {
    int count = 0;

    for (int i = 0; And[i] != '\0' && And[i] != '\n'; i++) {
        count++;
    }

    return count;
}
