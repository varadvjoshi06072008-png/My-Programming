//Syntax of the Data Structure
#include<stdio.h>
#include<string.h>
struct information{
char Name[100];
int Aadhar;
float percentage;
};
int main(){
struct information i1;
i1. Aadhar=1020;
strcpy(i1.Name, "Varad");
i1.percentage= 10.12;

printf(" Aadhar num is %d\n ", i1.Aadhar);
printf(" Name is %s\n", i1.Name);
printf("percentage is %f\n", i1.percentage);
}
