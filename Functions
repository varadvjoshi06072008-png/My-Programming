#include <stdio.h>

void bigger(int A, int B) {
    if (A > B) {
        printf("%d is bigger\n", A);
    }
    else if (A == B) {
        printf("Same numbers\n");
    }
    else {
        printf("%d is bigger\n", B);
    }
}

void smaller(int A, int B) {
    if (A < B) {
        printf("%d is smaller\n", A);
    }
    else if (A > B) {
        printf("%d is smaller\n", B);
    }
    else {
        printf("Same numbers\n");
    }
}

int main() {
    int A = 3;
    int B = 33;

    bigger(A, B);
    smaller(A, B);

    return 0;
}
